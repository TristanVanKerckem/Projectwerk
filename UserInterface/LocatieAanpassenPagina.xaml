<Window x:Class="ProjectbeheerUserInterface.LocatieAanpassenPagina"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectbeheerUserInterface"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="LocatieAanpassenPagina" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Wijk:" Grid.Row="1" Grid.Column="0"/>
        <TextBlock x:Name="WijkView" Text="{Binding Wijk}" Grid.Row="1" Grid.Column="1"/>
        <TextBox x:Name="WijkEditBox" Visibility="Collapsed" Grid.Row="1" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
        <Button Content="Pas Aan" Click="Pas_Aan_Click" Grid.Row="2" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="Wijk"/>

        <TextBlock Text="Straat:" Grid.Row="3" Grid.Column="0"/>
        <TextBlock x:Name="StraatView" Text="{Binding Straat}" Grid.Row="3" Grid.Column="1"/>
        <TextBox x:Name="StraatEditBox" Visibility="Collapsed" Grid.Row="3" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
        <Button Content="Pas Aan" Click="Pas_Aan_Click" Grid.Row="4" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="Straat"/>

        <TextBlock Text="Gemeente:" Grid.Row="5" Grid.Column="0"/>
        <TextBlock x:Name="GemeenteView" Text="{Binding Gemeente}" Grid.Row="5" Grid.Column="1"/>
        <TextBox x:Name="GemeenteEditBox" Visibility="Collapsed" Grid.Row="5" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
        <Button Content="Pas Aan" Click="Pas_Aan_Click" Grid.Row="6" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="Gemeente"/>

        <TextBlock Text="Postcode:" Grid.Row="7" Grid.Column="0"/>
        <TextBlock x:Name="PostcodeView" Text="{Binding Postcode}" Grid.Row="7" Grid.Column="1"/>
        <TextBox x:Name="PostcodeEditBox" Visibility="Collapsed" Grid.Row="7" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
        <Button Content="Pas Aan" Click="Pas_Aan_Click" Grid.Row="8" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="Postcode"/>

        <TextBlock Text="Huisnummer:" Grid.Row="9" Grid.Column="0"/>
        <TextBlock x:Name="HuisNummerView" Text="{Binding HuisNummer}" Grid.Row="9" Grid.Column="1"/>
        <TextBox x:Name="HuisNummerEditBox" Visibility="Collapsed" Grid.Row="9" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
        <Button Content="Pas Aan" Click="Pas_Aan_Click" Grid.Row="10" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="HuisNummer"/>
        
        <Button Content="Annuleer" HorizontalAlignment="Left" Height="46" Margin="58,71,0,0" Grid.Row="12" VerticalAlignment="Top" Width="90" Click="Annuleer_Click"/>
        <Button Content="Accepteer" HorizontalAlignment="Left" Height="46" Margin="200,71,0,0" Grid.Row="12" VerticalAlignment="Top" Width="90" Grid.Column="1" Click="Verzenden_Click"/>

    </Grid>
</Window>
