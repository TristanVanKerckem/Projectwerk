<Window x:Class="ProjectbeheerUserInterface.PartnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectbeheerUserInterface"
        mc:Ignorable="d"
        Height="420" Width="300"
        WindowStartupLocation="CenterOwner"
        Title="PartnerWindow">
    <StackPanel Margin="10">
        <TextBlock Text="Naam"/>
        <TextBox x:Name="NaamBox" Margin="0,0,0,10"/>

        <TextBlock Text="Email"/>
        <TextBox x:Name="EmailBox" Margin="0,0,0,10"/>
        
        <TextBlock Text="Wijk"/>
        <TextBox x:Name="WijkBox" Margin="0,0,0,10"/>

        <TextBlock Text="Straat"/>
        <TextBox x:Name="StraatBox" Margin="0,0,0,10"/>

        <TextBlock Text="Gemeente"/>
        <TextBox x:Name="GemeenteBox" Margin="0,0,0,10"/>

        <TextBlock Text="Postcode"/>
        <TextBox x:Name="PostcodeBox" Margin="0,0,0,10"/>

        <TextBlock Text="Huisnummer"/>
        <TextBox x:Name="HuisnummerBox" Margin="0,0,0,10"/>
        
        <TextBlock Text="Rol"/>
        <TextBox x:Name="RolBox" Margin="0,0,0,10"/>

        <DockPanel LastChildFill="False">
            <Button Content="Annuleren"
        Click="Annuleren_Click"
        DockPanel.Dock="Left"
        Width="100"/>

            <Button Content="Toevoegen"
                Click="Toevoegen_Click"
                DockPanel.Dock="Right"
                Width="100"/>
        </DockPanel>
    </StackPanel>
</Window>
