<Page x:Class="ProjectbeheerUserInterface.AanpassenPagina"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectbeheerUserInterface"
      xmlns:l="clr-namespace:ProjectbeheerBL.Domein;assembly=ProjectbeheerBL"
      xmlns:sys="clr-namespace:ProjectbeheerBL.Domein.Enums;assembly=ProjectbeheerBL"
      mc:Ignorable="d" d:DesignWidth="800"
      Title="AanpassenPagina"
      Height="422">

    <Grid Margin="30,10,30,30" Width="1200">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Project Aanpassen" FontSize="23" FontWeight="Bold" Margin="0,0,0,25" Grid.Row="0"/>

        <TextBlock Text="Projectnaam:" Grid.Row="1" Grid.Column="0"/>
        <TextBlock x:Name="TitelView" Text="{Binding Titel}" Grid.Row="1" Grid.Column="1"/>
        <TextBox x:Name="TitelEditBox" Visibility="Collapsed" Grid.Row="1" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
        <Button Content="Pas Aan" Click="Pas_Aan_Click" Grid.Row="2" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="Titel"/>

        <TextBlock Text="Beschrijving:" Grid.Row="3" Grid.Column="0" />
        <TextBlock x:Name="BeschrijvingView" Text="{Binding Beschrijving}" Grid.Row="3" Grid.Column="1"/>
        <TextBox x:Name="BeschrijvingEditBox" Visibility="Collapsed" Grid.Row="3" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
        <Button Content="Pas Aan" Click="Pas_Aan_Click" Grid.Row="4" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="Beschrijving"/>

        <TextBlock Text="StartDatum:" Grid.Row="5" Grid.Column="0" />
        <TextBlock  x:Name="StartDatumView" Text="{Binding StartDatum}" Grid.Row="5" Grid.Column="1"/>
        <DatePicker x:Name="StartDatumEditBox" SelectedDate="{Binding StartDatum, Mode=TwoWay}" Visibility="Collapsed" Grid.Row="5" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
        <Button Content="Pas Aan" Click="StartDatum_Click" Grid.Row="6" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="StartDatum"/>

        <TextBlock Text="Status:" Grid.Row="7" Grid.Column="0" />
        <ComboBox x:Name="StatusCombo" Grid.Column="1" Grid.Row="7" Width="200" HorizontalAlignment="Left" SelectedItem="{Binding Status}" />

        <TextBlock Text="Wijk:" Grid.Row="8" Grid.Column="0" />
        <TextBlock x:Name="WijkView" Text="{Binding Locatie.Wijk}" Grid.Row="8" Grid.Column="1"/>
        <TextBox x:Name="WijkEditBox" Visibility="Collapsed" Grid.Row="8" Grid.Column="1" Width="200" HorizontalAlignment="Left"/>
        <Button Content="Pas Aan" Click="Pas_Aan_Click" Grid.Row="9" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="Wijk"/>

        <TextBlock Text="Adress:" Grid.Row="11" Grid.Column="0" />
        <TextBlock  x:Name="AdresView" Text="{Binding Locatie}" Grid.Row="11" Grid.Column="1"/>
        <Button Content="Pas Aan" Click="Locatie_Click" Grid.Row="12" Grid.Column="1" Width="200" HorizontalAlignment="Left" Tag="Wijk"/>

        <TextBlock Text="Partners:" Grid.Row="13" Grid.Column="0" />
        <ItemsControl x:Name="Partners" ItemsSource="{Binding ProjectPartners}" Grid.Row="13" Grid.Column="1">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10"
                    Margin="2">
                        <StackPanel>
                            <TextBlock Text="{Binding Key.Naam}"
                        FontWeight="Bold"/>


                            <ItemsControl ItemsSource="{Binding Value}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <StackPanel Grid.Row="14"
            Grid.Column="1"
            Orientation="Horizontal"
            HorizontalAlignment="Left"
            Margin="0,10,0,0">

            <Button Content="Voeg Partner Toe"
            Click="Partner_Click"
            Width="200"
            Margin="0,0,100,0"/>

            <Button Content="Verzenden"
            Click="OnSubmit"
            Width="112"/>
        </StackPanel>
        <ItemsControl Grid.Row="15" Grid.ColumnSpan="2"
          ItemsSource="{Binding}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}" Margin="10"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
    <Page.Resources>
        <DataTemplate DataType="{x:Type l:GroeneRuimte}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Groene Ruimte: " Grid.Row="0" Grid.Column="0" />

                <TextBlock Text="Oppervlakte:" Grid.Row="1" Grid.Column="0" />
                <TextBlock Text="{Binding Oppervlakte}" Grid.Row="1" Grid.Column="1" Width="200"/>

                <TextBlock Text="Biodiversiteit:" Grid.Row="2" Grid.Column="0" />
                <TextBlock Text="{Binding Biodiversiteit}" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Text="Aantal Wandelpaden:" Grid.Row="3" Grid.Column="0" />
                <TextBlock Text="{Binding AantalWandelpaden}" Grid.Row="3" Grid.Column="1"/>

                <TextBlock Text="Is in een toeristische wandelroute" Grid.Row="4" Grid.Column="0" />
                <TextBlock Text="{Binding IsInToeristWandelroute}" Grid.Row="4" Grid.Column="1"/>

                <TextBlock Text="Beoordeling:" Grid.Row="5" Grid.Column="0" />
                <TextBlock Text="{Binding Beoordeling}" Grid.Row="5" Grid.Column="1"/>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type l:Stadsontwikkeling}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Stadsontwikkeling: " Grid.Row="0" Grid.Column="0" />
                <TextBlock Text="Bouwfirmas:" Grid.Row="1" Grid.Column="0" />
                <ItemsControl Grid.Row="1" Grid.Column="1"
          ItemsSource="{Binding Bouwfirmas}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Naam}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="VergunningStatus:" Grid.Row="2" Grid.Column="0" />
                <TextBlock Text="{Binding VergunningStatus}" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Text="Aantal Toegankelijkheid:" Grid.Row="3" Grid.Column="0" />
                <TextBlock Text="{Binding Toegankelijkheid}" Grid.Row="3" Grid.Column="1"/>

                <TextBlock Text="Is Bezienswaardig" Grid.Row="4" Grid.Column="0" />
                <TextBlock Text="{Binding IsBezienswaardig}" Grid.Row="4" Grid.Column="1"/>

                <TextBlock Text="Heeft Info:" Grid.Row="5" Grid.Column="0" />
                <TextBlock Text="{Binding HeeftInfo}" Grid.Row="5" Grid.Column="1"/>

                <TextBlock Text="Heeft Architecturele Waarde" Grid.Row="6" Grid.Column="0" />
                <TextBlock Text="{Binding HeeftArchitecturaleWaarde}" Grid.Row="6" Grid.Column="1"/>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type l:InnovatieWonen}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="InnovatieWonen: " Grid.Row="0" Grid.Column="0" />

                <TextBlock Text="Aantal WoonEenheden:" Grid.Row="1" Grid.Column="0"/>
                <TextBlock Text="{Binding AantalWooneenheden}" Grid.Row="1" Grid.Column="1"/>

                <TextBlock Text="Is Energiezuinig:" Grid.Row="2" Grid.Column="0"/>
                <TextBlock Text="{Binding HeeftRondleiding}" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Text="Heeft Showcase:" Grid.Row="3" Grid.Column="0"/>
                <TextBlock Text="{Binding HeeftShowcase}" Grid.Row="3" Grid.Column="1"/>

                <TextBlock Text="ArchitectuurScore:" Grid.Row="4" Grid.Column="0"/>
                <TextBlock Text="{Binding ArchitectuurScore}" Grid.Row="4" Grid.Column="1"/>

                <TextBlock Text="Heeft Samenwerking Erfgoed Of Toerisme:" Grid.Row="5" Grid.Column="0"/>
                <TextBlock Text="{Binding HeeftSamenwerkingErfgoedOfToerisme}" Grid.Row="5" Grid.Column="1"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>
</Page>
