<Page x:Class="ProjectbeheerUserInterface.DetailPagina"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectbeheerUserInterface"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DetailPagina">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Project Details" FontSize="28" FontWeight="Bold" 
               Margin="0,0,0,25" Grid.Row="0"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Projectnaam:" Grid.Row="1" Grid.Column="0"/>
                <TextBlock Text="{Binding Titel}" Grid.Row="1" Grid.Column="1" />

                <TextBlock Text="Beschrijving:" Grid.Row="2" Grid.Column="0" />
                <TextBlock Text="{Binding Beschrijving}" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap"/>

                <TextBlock Text="Oppervlakte:" Grid.Row="3" Grid.Column="0" />
                <TextBlock Text="{Binding Oppervlakte, StringFormat={}{0} m²}" Grid.Row="3" Grid.Column="1" />

                <TextBlock Text="Status:" Grid.Row="4" Grid.Column="0" />
                <TextBlock Text="{Binding Status}" Grid.Row="4" Grid.Column="1" />

                <TextBlock Text="Partners:" Grid.Row="5" Grid.Column="0" />
                <ItemsControl ItemsSource="{Binding ProjectPartners}" Grid.Row="5" Grid.Column="1" Margin="0,5,0,15">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Naam}" Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <TextBlock Text="StartDatum:" Grid.Row="6" Grid.Column="0" />
                <TextBlock Text="{Binding StartDatum}" Grid.Row="6" Grid.Column="1" />

                <TextBlock Text="Straat:" Grid.Row="7" Grid.Column="0" />
                <TextBlock Text="{Binding Locatie.Straat}" Grid.Row="7" Grid.Column="1" />

                <TextBlock Text="Gemeente:" Grid.Row="8" Grid.Column="0" />
                <TextBlock Text="{Binding Locatie.Gemeente}" Grid.Row="8" Grid.Column="1" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
