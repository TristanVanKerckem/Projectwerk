<Page x:Class="ProjectbeheerUserInterface.LogIn"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectbeheerUserInterface"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LogIn">

    <Grid>
        <TextBlock HorizontalAlignment="Left" Height="25" Margin="179,85,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="239"><Run Language="nl-nl" Text="Naam"/></TextBlock>
        <TextBox HorizontalAlignment="Left" Margin="179,110,0,0" TextWrapping="Wrap" Text="Uw naam" VerticalAlignment="Top" Width="221"/>
        <TextBlock HorizontalAlignment="Left" Height="25" Margin="179,146,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="239"><Run Language="nl-nl" Text="E-mail"/></TextBlock>
        <TextBox HorizontalAlignment="Left" Margin="179,176,0,0" TextWrapping="Wrap" Text="Voorbeeld@gmail.com" VerticalAlignment="Top" Width="222" TextChanged="TextBox_TextChanged"/>
        <Button Content="Log In" HorizontalAlignment="Left" Height="42" Margin="165,305,0,0" VerticalAlignment="Top" Width="113" Click="Log_In_Click"/>
        <Button Content="Registreer" HorizontalAlignment="Left" Height="42" Margin="543,305,0,0" VerticalAlignment="Top" Width="113" Click="Registreer_Click"/>

    </Grid>
</Page>
